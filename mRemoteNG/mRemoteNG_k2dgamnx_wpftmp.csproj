    </CrashReportToken>
  </PropertyGroup>
  <Target Name="WriteCrashReportToken" BeforeTargets="CoreCompile" DependsOnTargets="PrepareForBuild">
    <ItemGroup>
      <_CrashTokenAttr Include="System.Reflection.AssemblyMetadataAttribute">
        <_Parameter1>CrashReportToken</_Parameter1>
        <_Parameter2>$(CrashReportToken)</_Parameter2>
      </_CrashTokenAttr>
    </ItemGroup>
    <WriteCodeFragment AssemblyAttributes="@(_CrashTokenAttr)" Language="C#" OutputDirectory="$(IntermediateOutputPath)" OutputFile="CrashReportToken.g.cs">
      <Output TaskParameter="OutputFile" ItemName="Compile" />
      <Output TaskParameter="OutputFile" ItemName="FileWrites" />
    </WriteCodeFragment>
  </Target>
